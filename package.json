{
    "name": "f1",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "api:generate": "apicraft generate -c src/shared/api/apicraft.config.ts && prettier \"src/shared/api/generated/**/*.ts\" --write",
        "typecheck": "tsc -b --noEmit",
        "lint": "oxlint --ignore-pattern src/shared/api/generated/**",
        "lint:fix": "oxlint --ignore-pattern src/shared/api/generated/** --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "check": "npm run typecheck && npm run lint && npm run format:check",
        "prepare": "husky"
    },
    "dependencies": {
        "@base-ui/react": "^1.6.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@siberiacancode/apicraft": "^1.12.0",
        "@tailwindcss/vite": "^4.3.1",
        "@tanstack/react-query": "^5.101.2",
        "axios": "^1.18.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.4.0",
        "lucide-react": "^1.22.0",
        "radix-ui": "^1.6.0",
        "react": "^19.2.7",
        "react-day-picker": "^10.0.1",
        "react-dom": "^19.2.7",
        "react-router": "^8.0.1",
        "shadcn": "^4.12.0",
        "socket.io-client": "^4.8.3",
        "tailwind": "^4.0.0",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.1",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@rolldown/plugin-babel": "^0.2.3",
        "@types/babel__core": "^7.20.5",
        "@types/node": "^24.13.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "oxlint": "^1.71.0",
        "prettier": "^3.9.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "~6.0.2",
        "vite": "^8.1.0"
    }
}
